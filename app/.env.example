# ─── Engine Connection (server-side) ──────────────────────────
# Internal URL of the securelogic-engine API service, used by
# Next.js server actions and route handlers. In production, set
# this to the Render private service URL so traffic stays within
# the Render network.
ENGINE_API_URL=http://localhost:4000

# ─── Engine Connection (client-side) ──────────────────────────
# Public URL of the securelogic-engine API, bundled into the
# browser for SSO check-domain and SSO login redirects. MUST be
# reachable from the end user's browser (i.e. the public Render
# URL, not the private one).
NEXT_PUBLIC_ENGINE_URL=http://localhost:4000

# ─── Session ──────────────────────────────────────────────────
# Must be at least 32 characters
# Generate: openssl rand -hex 32
SESSION_SECRET=dev_session_secret_REPLACE_ME

# ─── Site ─────────────────────────────────────────────────────
# Public URL of the marketing site — used for "Get Started" and pricing links
NEXT_PUBLIC_SITE_URL=https://www.securelogicai.com
