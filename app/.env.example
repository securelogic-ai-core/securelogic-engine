# ─── Engine Connection ────────────────────────────────────────
# Internal URL of the securelogic-engine API service
# In production, use the Render private service URL
ENGINE_URL=http://localhost:4000
ENGINE_API_URL=http://localhost:4000

# ─── Session ──────────────────────────────────────────────────
# Must be at least 32 characters
# Generate: openssl rand -hex 32
SESSION_SECRET=dev_session_secret_REPLACE_ME

# ─── Site ─────────────────────────────────────────────────────
# Public URL of the marketing site — used for "Get Started" and pricing links
NEXT_PUBLIC_SITE_URL=https://www.securelogicai.com
