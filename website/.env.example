# SecureLogic AI — marketing website (Next.js) environment.
#
# All values are environment-specific. In staging builds these MUST point at
# staging surfaces so the staging site never links to, posts to, or emits
# canonical metadata for production. The committed defaults below are local-dev
# values — never production hosts — so a missing value fails locally instead of
# silently drifting to prod.

# Public URL of the securelogic-app service. Used by Nav/Footer login & register
# CTAs. Prod: https://app.securelogicai.com · Staging: the staging app URL.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Canonical public URL of THIS marketing site (metadataBase / canonical / OG /
# sitemap). Prod: https://www.securelogicai.com · Staging: the staging site URL.
NEXT_PUBLIC_SITE_URL=http://localhost:3001

# Public origin of the SecureLogic engine API the Brief signup form POSTs to.
# Prod: https://api.securelogicai.com · Staging: the staging engine URL.
NEXT_PUBLIC_API_URL=http://localhost:4000
