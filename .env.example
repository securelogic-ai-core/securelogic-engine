# -----------------------------
# SecureLogic Engine (DEV)
# -----------------------------

NODE_ENV=development
PORT=4000

DATABASE_URL=postgresql://user:password@localhost:5432/securelogic

REDIS_URL=redis://127.0.0.1:6379

# Admin access (required)
SECURELOGIC_ADMIN_KEY=sl_admin_REPLACE_ME
SECURELOGIC_ADMIN_ALLOWED_IPS=127.0.0.1/32

# Issue signing (required)
SECURELOGIC_SIGNING_SECRET=sl_signing_REPLACE_ME_32chars_min

# Session secret (required in prod — defaults to "dev-secret" if omitted)
SESSION_SECRET=dev_session_secret_REPLACE_ME

# LemonSqueezy webhook (optional in dev, required in prod)
LEMON_WEBHOOK_SECRET=lemon_webhook_REPLACE_ME

# -----------------------------
# Stripe billing (required in prod — billing routes return 503 without these)
# -----------------------------
STRIPE_SECRET_KEY=sk_test_REPLACE_ME
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME
STRIPE_PRICE_ID_PROFESSIONAL=price_REPLACE_ME
STRIPE_PRICE_ID_TEAM=price_REPLACE_ME
STRIPE_SUCCESS_URL=https://app.securelogicai.com/success
STRIPE_CANCEL_URL=https://app.securelogicai.com/cancel
STRIPE_PORTAL_RETURN_URL=https://app.securelogicai.com/account

# -----------------------------
# Resend email (optional in dev — required in prod for newsletter delivery and recovery emails)
# -----------------------------
RESEND_API_KEY=re_REPLACE_ME
RESEND_WEBHOOK_SECRET=resend_whsec_REPLACE_ME
NEWSLETTER_FROM_EMAIL=brief@securelogicai.com

# Unsubscribe link signing (required in prod — CAN-SPAM compliance)
UNSUBSCRIBE_SECRET=unsub_REPLACE_ME_32chars_min

# Base URL for unsubscribe links and account recovery emails
APP_BASE_URL=https://app.securelogicai.com

# LLM analysis (optional — enables AI-generated signal analysis in the Intelligence Brief)
# Without this key, the pipeline falls back to rule-based template analysis.
# Recommended model: claude-haiku-4-5-20251001 (low cost, ~$0.01–0.03 per brief)
ANTHROPIC_API_KEY=

# Feature flags (optional)
SECURELOGIC_DISABLE_PUBLIC_API=false
ENABLE_DEBUG_ROUTES=false
ALLOW_ADMIN_TIER_ASSIGNMENT=false
