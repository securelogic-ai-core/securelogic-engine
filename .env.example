# ─── Runtime ─────────────────────────────────────────────────
NODE_ENV=development
PORT=4000

# ─── Database ─────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/securelogic

# ─── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://127.0.0.1:6379

# ─── Authentication ───────────────────────────────────────────
# JWT signing secret — required for customer portal auth (HS256).
# Min 32 chars, max 512 chars — enforced at boot in production
# (engine refuses to start otherwise). Provision as hex/base64,
# not a UTF-8 passphrase, since the check is on .length not bytes.
# Generate: openssl rand -hex 32
JWT_SECRET=

# Session cookie encryption key (min 32 chars)
# Defaults to "dev-secret" in development; MUST be set in production
# Generate: openssl rand -hex 32
SESSION_SECRET=dev_session_secret_REPLACE_ME

# ─── Admin ────────────────────────────────────────────────────
# Admin API key (min 16 chars; comma-separate for key rotation: "key1,key2")
SECURELOGIC_ADMIN_KEY=sl_admin_REPLACE_ME

# IP allowlist for /admin routes (CIDR, comma-separated)
# 0.0.0.0/0 is forbidden. Use 127.0.0.1/32 for local dev.
SECURELOGIC_ADMIN_ALLOWED_IPS=127.0.0.1/32

# Issue signing secret (min 16 chars)
SECURELOGIC_SIGNING_SECRET=sl_signing_REPLACE_ME_32chars_min

# ─── Anthropic AI ─────────────────────────────────────────────
# Required for AI signal enrichment and brief generation
# Without this, the pipeline falls back to rule-based template analysis
ANTHROPIC_API_KEY=

# ─── OpenAI ───────────────────────────────────────────────────
# OpenAI API key for Whisper voice transcription
# (optional — voice search disabled if not set)
OPENAI_API_KEY=sk-...your-key-here

# ─── Stripe ───────────────────────────────────────────────────
# Billing routes return 503 without these
STRIPE_SECRET_KEY=sk_test_REPLACE_ME
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME

# Price IDs — one per paid tier (from Stripe Dashboard > Products)
STRIPE_PRICE_ID_PROFESSIONAL=price_REPLACE_ME
STRIPE_PRICE_ID_TEAM=price_REPLACE_ME

# Redirect URLs for checkout and portal flows
STRIPE_SUCCESS_URL=https://app.securelogicai.com/dashboard?upgraded=true
STRIPE_CANCEL_URL=https://app.securelogicai.com/dashboard
STRIPE_PORTAL_RETURN_URL=https://app.securelogicai.com/account

# Optional: Stripe Customer Portal configuration ID (from Dashboard > Billing > Customer Portal)
# Required to enable plan upgrades, downgrades, and cancellation in the portal
STRIPE_PORTAL_CONFIGURATION_ID=

# ─── Email (Resend) ───────────────────────────────────────────
# Required in production for newsletter delivery and account recovery emails
RESEND_API_KEY=re_REPLACE_ME
RESEND_WEBHOOK_SECRET=resend_whsec_REPLACE_ME
NEWSLETTER_FROM_EMAIL=brief@securelogicai.com

# ─── App Integration ──────────────────────────────────────────
# Base URL for unsubscribe links and account recovery emails
APP_BASE_URL=https://app.securelogicai.com

# Engine's own public origin, used to build the SAML SSO ACS URL the IdP posts
# back to. Set per environment (staging engine → staging URL) so SSO never bounces
# staging users into production. Falls back to the prod engine when unset.
ENGINE_URL_BASE=https://securelogic-engine.onrender.com

# Unsubscribe link signing secret (required in prod — CAN-SPAM compliance)
UNSUBSCRIBE_SECRET=unsub_REPLACE_ME_32chars_min

# ─── Webhook Alerts ───────────────────────────────────────────
# Slack or Discord incoming webhook for worker failure alerts (optional)
ALERT_WEBHOOK_URL=

# LemonSqueezy webhook secret (legacy — optional)
LEMON_WEBHOOK_SECRET=lemon_webhook_REPLACE_ME

# ─── Feature Flags ────────────────────────────────────────────
SECURELOGIC_DISABLE_PUBLIC_API=false
ENABLE_DEBUG_ROUTES=false
ALLOW_ADMIN_TIER_ASSIGNMENT=false

# Set to true to log per-signal scoring explanations (verbose — dev only)
SECURELOGIC_EXPLAIN=false
