{
  "name": "securelogic-engine",
  "version": "0.4.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "securelogic-engine": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "clean": "rm -rf dist",
    "build": "npx tsc -p tsconfig.prod.json",
    "typecheck": "npx tsc -p tsconfig.ci.json",
    "lint": "eslint \"src/**/*.{ts,tsx,js}\"",
    "test": "vitest run",
    "test:prod": "vitest run src/_frozen_prod/__tests__",
    "check": "bash scripts/guard-imports.sh && npm run lint && npm run typecheck && npm run build && npm run test:prod",
    "ci": "bash scripts/check-contract-version.sh && npm run typecheck && npm run build"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "~25.0.3",
    "@typescript-eslint/eslint-plugin": "^8.53.1",
    "@typescript-eslint/parser": "^8.53.1",
    "eslint": "^9.39.2",
    "eslint-plugin-boundaries": "^5.3.1",
    "typescript": "~5.9.3",
    "vitest": "~4.0.16"
  },
  "dependencies": {
    "@prisma/client": "^7.3.0",
    "ajv": "~8.17.1",
    "ajv-formats": "~3.0.1",
    "better-sqlite3": "^12.6.2",
    "dotenv": "^17.2.3",
    "json-canonicalize": "^2.0.0",
    "pdfkit": "^0.17.2",
    "prisma": "^7.3.0",
    "securelogic-contracts": "^0.1.2",
    "tsx": "^4.21.0",
    "zod": "^4.3.4"
  }
}
