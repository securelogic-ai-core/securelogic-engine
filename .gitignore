# =========================
# ENV FILES (SECRETS)
# =========================
.env
.env.*
!.env.example

# =========================
# BUILD OUTPUT
# =========================
dist/
dist-*/
node_modules/

# =========================
# TS BUILD INFO
# =========================
*.tsbuildinfo

# =========================
# LOCAL ARTIFACTS
# =========================
reports/*.json
test.db
test.db-*
*.sqlite
*.sqlite-*

# WAL/SHM
*-wal
*-shm

# =========================
# SECRETS / KEYS
# =========================
keys/
*.pem
# KeyStore.loadOrCreate writes PEM blocks inside JSON; *.pem above doesn't catch them.
*-keypair.json

# =========================
# REDIS DUMP
# =========================
dump.rdb

# =========================
# GENERATED ISSUE ARTIFACTS
# =========================
data/issues/

# =========================
# LOCAL SCRIPTS
# =========================
scripts/generate-issue.ts

# =========================
# DATABASE FILES
# =========================
*.db
*.db-*

# =========================
# SHELL / TOOL ACCIDENTS
# =========================
# Empty files created by accidental shell commands
=
^C
c.id
node
tsc
securelogic-engine@*

# =========================
# BACKUP / SAVE FILES
# =========================
*.json.save
*.save
*.backup.json

# =========================
# LOCAL LOGS
# =========================
type-errors.log
# =========================
# Intelligence brief synthesis driver — local test corpus
# =========================
