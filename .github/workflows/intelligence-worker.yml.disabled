name: SecureLogic Intelligence Worker

on:
  schedule:
    - cron: "0 13 * * MON"
  workflow_dispatch:

jobs:
  run-intelligence-worker:
    runs-on: ubuntu-latest

    steps:
      - name: Checkout repository
        uses: actions/checkout@de0fac2e4500dabe0009e67214ff5f5447ce83dd # v6.0.2

      - name: Setup Node
        uses: actions/setup-node@48b55a011bda9f5d6aeb4c2d9c7362e8dae4041e # v6.4.0
        with:
          node-version: 20

      - name: Install dependencies
        run: npm ci

      - name: Run intelligence worker
        env:
          DATABASE_URL: ${{ secrets.DATABASE_URL }}
          # Resend — required for newsletter email delivery
          RESEND_API_KEY: ${{ secrets.RESEND_API_KEY }}
          NEWSLETTER_FROM_EMAIL: ${{ secrets.NEWSLETTER_FROM_EMAIL }}
          # Required for CAN-SPAM-compliant unsubscribe links in outbound emails
          UNSUBSCRIBE_SECRET: ${{ secrets.UNSUBSCRIBE_SECRET }}
          APP_BASE_URL: ${{ secrets.APP_BASE_URL }}
          # Optional — enables AI-generated signal analysis; falls back to rule-based if absent
          ANTHROPIC_API_KEY: ${{ secrets.ANTHROPIC_API_KEY }}
          SECURELOGIC_ADMIN_KEY: ${{ secrets.SECURELOGIC_ADMIN_KEY }}
          SECURELOGIC_SIGNING_SECRET: ${{ secrets.SECURELOGIC_SIGNING_SECRET }}
          ALERT_WEBHOOK_URL: ${{ secrets.ALERT_WEBHOOK_URL }}
        run: npx tsx services/intelligence-worker/src/runner.ts
